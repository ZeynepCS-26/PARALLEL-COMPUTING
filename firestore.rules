rules_version = '2';
// Triggering sync
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'isPublic'])
        && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 128
        && data.isPublic is bool
        && (!('createdAt' in data.keys()) || (data.createdAt is timestamp || data.createdAt is int));
    }
    
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || existing().isPublic == true);
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUserProfile(incoming());
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUserProfile(incoming()) && incoming().userId == existing().userId;
    }
    
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'description', 'code', 'simulationResult', 'completedAt'])
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 1000
        && data.code is string && data.code.size() <= 10000
        && data.simulationResult is string && data.simulationResult.size() <= 10000
        && (data.completedAt is timestamp || data.completedAt is int);
    }
    
    match /users/{userId}/tasks/{taskId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || get(/databases/$(database)/documents/users/$(userId)).data.isPublic == true);
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && exists(/databases/$(database)/documents/users/$(userId)) && isValidId(taskId) && isValidTask(incoming());
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidId(taskId) && isValidTask(incoming());
    }
  }
}
